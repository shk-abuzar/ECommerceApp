@model ECommerceApp.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = "Products";
}
<div class="row">
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-title">Filter Products</h6>
                <form asp-action="Index" method="get">
                    <div class="mb-2">
                        <input type="text" name="search" value="@Model.Search"
                               class="form-control form-control-sm" placeholder="Search..." />
                    </div>
                    <div class="mb-2">
                        <select name="categoryId" class="form-select form-select-sm">
                            <option value="">All Categories</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm w-100">Apply</button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100 mt-1">Reset</a>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4>Products <span class="badge bg-secondary">@Model.Products.Count()</span></h4>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-success btn-sm">
                    <i class="fas fa-plus"></i> Add Product
                </a>
            }
        </div>
        @if (!Model.Products.Any())
        {
            <div class="alert alert-info">No products found.</div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-3 g-3">
                @foreach (var product in Model.Products)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm">
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name"
                                 style="height:180px; object-fit:cover;"
                                 onerror="this.src='https://placehold.co/400x180?text=No+Image'" />
                            <div class="card-body d-flex flex-column">
                                <span class="badge bg-light text-dark mb-1">@product.Category?.Name</span>
                                <h6 class="card-title">@product.Name</h6>
                                <p class="text-muted small flex-grow-1">
                                    @(product.Description.Length > 70 ? product.Description[..70] + "…" : product.Description)
                                </p>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <span class="text-success fw-bold">$@product.Price.ToString("F2")</span>
                                    <span class="text-muted small">Stock: @product.StockQuantity</span>
                                </div>
                                <a asp-action="Details" asp-route-id="@product.Id"
                                   class="btn btn-primary btn-sm mt-2">View Details</a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@product.Id"
                                       class="btn btn-warning btn-sm mt-1">Edit</a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>