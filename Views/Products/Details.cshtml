@model ECommerceApp.ViewModels.ProductDetailViewModel
@{
    ViewData["Title"] = Model.Product.Name;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="Products" asp-action="Index">Products</a></li>
        <li class="breadcrumb-item active">@Model.Product.Name</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-5">
        <img src="@Model.Product.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Product.Name"
             onerror="this.src='/images/no-image.png'" />
    </div>
    <div class="col-md-7">
        <span class="badge bg-secondary mb-2">@Model.Product.Category?.Name</span>
        <h2>@Model.Product.Name</h2>
        <p class="text-muted">@Model.Product.Description</p>
        <h3 class="text-success">$@Model.Product.Price.ToString("F2")</h3>

        <!-- Live stock indicator -->
        <p id="stock-status" class="@(Model.Product.StockQuantity > 0 ? "text-success" : "text-danger")">
            @(Model.Product.StockQuantity > 0
                ? $"✓ In Stock ({Model.Product.StockQuantity} available)"
                : "✗ Out of Stock")
        </p>

        <div id="add-to-cart-section">
            @if (Model.Product.StockQuantity > 0)
            {
                <form asp-controller="Cart" asp-action="Add" method="post">
                    <input type="hidden" name="productId" value="@Model.Product.Id" />
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <label class="form-label mb-0">Qty:</label>
                        <input type="number" name="quantity" id="qty-input" value="1" min="1"
                               max="@Model.Product.StockQuantity" class="form-control" style="width:80px" />
                    </div>
                    @Html.AntiForgeryToken()
                    <button type="submit" id="add-to-cart-btn" class="btn btn-primary">
                        <i class="fas fa-cart-plus me-1"></i> Add to Cart
                    </button>
                </form>
            }
            else
            {
                <button class="btn btn-primary" disabled>Out of Stock</button>
            }
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary mt-3">
            <i class="fas fa-arrow-left me-1"></i> Back to Products
        </a>
    </div>
</div>

@section Scripts {
    <script>
        const productId = @Model.Product.Id;
        const stockApiUrl = `/Products/GetStock?id=${productId}`;

        function updateStockUI(stock) {
            const statusEl = document.getElementById('stock-status');
            const qtyInput = document.getElementById('qty-input');
            const addBtn = document.getElementById('add-to-cart-btn');

            if (stock > 0) {
                statusEl.textContent = `✓ In Stock (${stock} available)`;
                statusEl.className = 'text-success';
                if (qtyInput) qtyInput.max = stock;
                if (addBtn) addBtn.disabled = false;
            } else {
                statusEl.textContent = '✗ Out of Stock';
                statusEl.className = 'text-danger';
                if (qtyInput) qtyInput.disabled = true;
                if (addBtn) {
                    addBtn.disabled = true;
                    addBtn.textContent = 'Out of Stock';
                }
            }
        }

        async function pollStock() {
            try {
                const res = await fetch(stockApiUrl);
                if (res.ok) {
                    const data = await res.json();
                    updateStockUI(data.stock);
                }
            } catch (e) {
                // silently ignore network errors
            }
        }

        // Poll every 5 seconds
        setInterval(pollStock, 5000);
    </script>
}
