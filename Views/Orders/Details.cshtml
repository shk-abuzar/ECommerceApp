@model ECommerceApp.Models.Order
@{
    ViewData["Title"] = $"Order #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-box me-2"></i>Order #@Model.Id</h2>
    <span class="badge fs-6 @(Model.Status switch {
        ECommerceApp.Models.OrderStatus.Delivered  => "bg-success",
        ECommerceApp.Models.OrderStatus.Shipped    => "bg-primary",
        ECommerceApp.Models.OrderStatus.Processing => "bg-warning text-dark",
        ECommerceApp.Models.OrderStatus.Cancelled  => "bg-danger",
        _ => "bg-secondary"
    })">@Model.Status</span>
</div>

<div class="row">
    <!-- Order Items -->
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header"><strong>Items Ordered</strong></div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th>Price</th>
                            <th>Qty</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>@item.Product?.Name</td>
                                <td>$@item.UnitPrice.ToString("F2")</td>
                                <td>@item.Quantity</td>
                                <td>$@item.SubTotal.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Total</td>
                            <td class="fw-bold text-success">$@Model.TotalAmount.ToString("F2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- Shipping Info -->
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><strong>Shipping Details</strong></div>
            <div class="card-body">
                <p class="mb-1"><strong>Address:</strong> @Model.ShippingAddress</p>
                <p class="mb-1"><strong>City:</strong> @Model.City</p>
                <p class="mb-1"><strong>Postal Code:</strong> @Model.PostalCode</p>
                <p class="mb-1"><strong>Country:</strong> @Model.Country</p>
                <p class="mb-1"><strong>Phone:</strong> @Model.PhoneNumber</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><strong>Order Info</strong></div>
            <div class="card-body">
                <p class="mb-1"><strong>Order Date:</strong> @Model.OrderDate.ToString("MMM dd, yyyy")</p>
                <p class="mb-1"><strong>Order ID:</strong> #@Model.Id</p>
                <p class="mb-0"><strong>Status:</strong> @Model.Status</p>
            </div>
        </div>
    </div>
</div>

<a asp-action="Index" class="btn btn-outline-secondary mt-2">
    <i class="fas fa-arrow-left me-1"></i> Back to Orders
</a>
