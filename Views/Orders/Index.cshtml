@model IEnumerable<ECommerceApp.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<h2><i class="fas fa-box me-2"></i>My Orders</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No orders yet. <a asp-controller="Products" asp-action="Index">Start shopping</a>
    </div>
}
else
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Order #</th>
                <th>Date</th>
                <th>Items</th>
                <th>Total</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>#@order.Id</td>
                    <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                    <td>@order.OrderItems.Count item(s)</td>
                    <td>$@order.TotalAmount.ToString("F2")</td>
                    <td>
                        <span class="badge @(order.Status switch {
                            ECommerceApp.Models.OrderStatus.Delivered  => "bg-success",
                            ECommerceApp.Models.OrderStatus.Shipped    => "bg-primary",
                            ECommerceApp.Models.OrderStatus.Processing => "bg-warning text-dark",
                            ECommerceApp.Models.OrderStatus.Cancelled  => "bg-danger",
                            _ => "bg-secondary"
                        })">@order.Status</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@order.Id"
                           class="btn btn-sm btn-outline-primary">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
