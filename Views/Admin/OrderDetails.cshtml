@model ECommerceApp.Models.Order
@{
    ViewData["Title"] = $"Order #{Model.Id}";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Order #@Model.Id</h4>
    <a asp-action="Orders" class="btn btn-outline-secondary btn-sm">← Back to Orders</a>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <!-- Items -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white"><strong>Order Items</strong></div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr><th>Product</th><th>Price</th><th>Qty</th><th>Subtotal</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>@item.Product?.Name</td>
                                <td>$@item.UnitPrice.ToString("F2")</td>
                                <td>@item.Quantity</td>
                                <td>$@item.SubTotal.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Total</td>
                            <td class="fw-bold text-success">$@Model.TotalAmount.ToString("F2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Update Status -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><strong>Update Order Status</strong></div>
            <div class="card-body">
                <form asp-action="UpdateOrderStatus" method="post" class="d-flex gap-2 align-items-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <select name="status" class="form-select">
                        @foreach (var s in Enum.GetValues<ECommerceApp.Models.OrderStatus>())
                        {
                            <option value="@s" selected="@(Model.Status == s)">@s</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-primary text-nowrap">Update Status</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Customer Info -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white"><strong>Customer</strong></div>
            <div class="card-body">
                <p class="mb-1"><i class="fas fa-user me-2 text-muted"></i>@(Model.User?.FullName ?? "—")</p>
                <p class="mb-0"><i class="fas fa-envelope me-2 text-muted"></i>@(Model.User?.Email ?? "—")</p>
            </div>
        </div>

        <!-- Shipping Info -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white"><strong>Shipping Address</strong></div>
            <div class="card-body">
                <p class="mb-1">@Model.ShippingAddress</p>
                <p class="mb-1">@Model.City, @Model.PostalCode</p>
                <p class="mb-1">@Model.Country</p>
                <p class="mb-0"><i class="fas fa-phone me-2 text-muted"></i>@Model.PhoneNumber</p>
            </div>
        </div>

        <!-- Order Info -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><strong>Order Info</strong></div>
            <div class="card-body">
                <p class="mb-1"><strong>Date:</strong> @Model.OrderDate.ToString("MMM dd, yyyy HH:mm")</p>
                <p class="mb-0">
                    <strong>Status:</strong>
                    <span class="badge @(Model.Status switch {
                        ECommerceApp.Models.OrderStatus.Delivered  => "bg-success",
                        ECommerceApp.Models.OrderStatus.Shipped    => "bg-primary",
                        ECommerceApp.Models.OrderStatus.Processing => "bg-warning text-dark",
                        ECommerceApp.Models.OrderStatus.Cancelled  => "bg-danger",
                        _ => "bg-secondary"
                    })">@Model.Status</span>
                </p>
            </div>
        </div>
    </div>
</div>
