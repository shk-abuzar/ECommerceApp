@model ECommerceApp.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #0d6efd!important">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">Total Revenue</p>
                        <h3 class="fw-bold text-primary mb-0">$@Model.TotalRevenue.ToString("N2")</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="fas fa-dollar-sign text-primary fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #198754!important">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">Total Orders</p>
                        <h3 class="fw-bold text-success mb-0">@Model.TotalOrders</h3>
                        <small class="text-warning">@Model.PendingOrders pending</small>
                    </div>
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="fas fa-shopping-bag text-success fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #6f42c1!important">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">Products</p>
                        <h3 class="fw-bold text-purple mb-0" style="color:#6f42c1">@Model.TotalProducts</h3>
                        @if (Model.LowStockCount > 0)
                        {
                            <small class="text-danger">@Model.LowStockCount low stock</small>
                        }
                    </div>
                    <div class="rounded-3 p-3" style="background:rgba(111,66,193,0.1)">
                        <i class="fas fa-box fs-4" style="color:#6f42c1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #fd7e14!important">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">Total Users</p>
                        <h3 class="fw-bold mb-0" style="color:#fd7e14">@Model.TotalUsers</h3>
                    </div>
                    <div class="rounded-3 p-3" style="background:rgba(253,126,20,0.1)">
                        <i class="fas fa-users fs-4" style="color:#fd7e14"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Recent Orders -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold">Recent Orders</h6>
                <a asp-action="Orders" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Order #</th><th>Customer</th><th>Amount</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.RecentOrders)
                        {
                            <tr>
                                <td><a asp-action="OrderDetails" asp-route-id="@o.Id">#@o.Id</a></td>
                                <td>@(o.User?.Email ?? "Guest")</td>
                                <td>$@o.TotalAmount.ToString("F2")</td>
                                <td>
                                    <span class="badge @(o.Status switch
                                          {
                                              OrderStatus.Delivered => "bg-success",
                                              OrderStatus.Shipped => "bg-primary",
                                              OrderStatus.Processing => "bg-warning text-dark",
                                              OrderStatus.Cancelled => "bg-danger",
                                              _ => "bg-secondary"
                                          })">@o.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Top Products -->
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h6 class="mb-0 fw-bold">Top Products by Revenue</h6>
            </div>
            <div class="card-body">
                @foreach (var p in Model.TopProducts)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small fw-500">@p.Name</span>
                            <span class="small text-success fw-bold">$@p.Revenue.ToString("F0")</span>
                        </div>
                        @{
                            var maxRev = Model.TopProducts.Max(x => x.Revenue);
                            var pct = maxRev > 0 ? (int)(p.Revenue / maxRev * 100) : 0;
                        }
                        <div class="progress" style="height:6px">
                            <div class="progress-bar bg-primary" style="width:@pct%"></div>
                        </div>
                        <small class="text-muted">@p.Quantity units sold</small>
                    </div>
                }
                @if (!Model.TopProducts.Any())
                {
                    <p class="text-muted text-center py-3">No sales data yet.</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Order Status Summary -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <h6 class="mb-0 fw-bold">Orders by Status</h6>
    </div>
    <div class="card-body">
        <div class="row text-center">
            @foreach (var s in Model.OrdersByStatus)
            {
                <div class="col">
                    <h4 class="fw-bold @(s.Status switch
                        {
                            OrderStatus.Delivered => "text-success",
                            OrderStatus.Shipped => "text-primary",
                            OrderStatus.Processing => "text-warning",
                            OrderStatus.Cancelled => "text-danger",
                            _ => "text-secondary"
                        })">
                        @s.Count
                    </h4>
                    <p class="text-muted small mb-0">@s.Status</p>
                </div>
            }
        </div>
    </div>
</div>
