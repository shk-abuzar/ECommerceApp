<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SHOPNET</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@300;400;500;600&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- TOP ANNOUNCEMENT BAR -->
    <div class="announcement-bar">
        <span>FREE SHIPPING ON ORDERS OVER $150 &nbsp;&nbsp;·&nbsp;&nbsp; NEW ARRIVALS EVERY FRIDAY</span>
    </div>

    <!-- NAVIGATION -->
    <header class="site-header" id="site-header">
        <nav class="nav-container">
            <!-- Left Nav Links -->
            <ul class="nav-links nav-left">
                <li><a asp-controller="Home" asp-action="Index">HOME</a></li>
                <li><a asp-controller="Products" asp-action="Index">ALL</a></li>
                @await Component.InvokeAsync("NavCategories")
            </ul>

            <!-- Center Logo -->
            <a asp-controller="Home" asp-action="Index" class="site-logo">SHOPNET</a>

            <!-- Right Nav -->
            <ul class="nav-links nav-right">
                <li><a asp-controller="Products" asp-action="Index">COLLECTIONS</a></li>

                <!-- Account icon: shows My Account if logged in, Login if not -->
                <li class="nav-icon-link">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-area="" asp-controller="Orders" asp-action="Index" title="My Orders">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                        </a>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" title="Login">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                        </a>
                    }
                </li>

                <!-- Search icon -->
                <li class="nav-icon-link">
                    <a asp-controller="Products" asp-action="Index" title="Search">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                    </a>
                </li>

                <!-- Cart icon -->
                <li class="nav-icon-link cart-link">
                    <a asp-controller="Cart" asp-action="Index" title="Cart">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                            <line x1="3" y1="6" x2="21" y2="6" />
                            <path d="M16 10a4 4 0 0 1-8 0" />
                        </svg>
                        <span class="cart-count" id="cart-count">0</span>
                    </a>
                </li>
            </ul>
        </nav>
    </header>

    <!-- MOBILE HEADER -->
    <header class="mobile-header">
        <button class="mobile-menu-btn" id="mobileMenuBtn">
            <span></span><span></span><span></span>
        </button>
        <a asp-controller="Home" asp-action="Index" class="site-logo">SHOPNET</a>
        <a asp-controller="Cart" asp-action="Index" class="mobile-cart">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                <line x1="3" y1="6" x2="21" y2="6" />
                <path d="M16 10a4 4 0 0 1-8 0" />
            </svg>
        </a>
    </header>

    <!-- MOBILE MENU -->
    <div class="mobile-menu" id="mobileMenu">
        <a asp-controller="Home" asp-action="Index">HOME</a>
        <a asp-controller="Products" asp-action="Index">ALL PRODUCTS</a>
        @await Component.InvokeAsync("NavCategories", new { mobile = true })
        <a asp-controller="Products" asp-action="Index">COLLECTIONS</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Orders" asp-action="Index">MY ORDERS</a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Index">ADMIN</a>
            }
            <a asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">LOGOUT</a>
        }
        else
        {
            <a asp-area="Identity" asp-page="/Account/Login">LOGIN</a>
            <a asp-area="Identity" asp-page="/Account/Register">REGISTER</a>
        }
    </div>

    <!-- GLOBAL ALERTS -->
    @if (TempData["Success"] != null)
    {
        <div style="background:#f0f9f0;border-bottom:1px solid #4caf50;color:#2e7d32;padding:12px 40px;font-family:'Montserrat',sans-serif;font-size:13px;letter-spacing:0.05em;">
            ✓ @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div style="background:#fff0f0;border-bottom:1px solid #e57373;color:#c62828;padding:12px 40px;font-family:'Montserrat',sans-serif;font-size:13px;letter-spacing:0.05em;">
            ✗ @TempData["Error"]
        </div>
    }

    <!-- PAGE CONTENT -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="footer-grid">
            <div class="footer-brand">
                <span class="footer-logo">SHOPNET</span>
                <p>Curated fashion for the modern individual. Quality, style, and authenticity in every piece.</p>
            </div>
            <div class="footer-col">
                <h4>SHOP</h4>
                <a asp-controller="Products" asp-action="Index">All Products</a>
                <a asp-controller="Products" asp-action="Index" asp-route-categoryId="1">Electronics</a>
                <a asp-controller="Products" asp-action="Index" asp-route-categoryId="2">Clothing</a>
                <a asp-controller="Products" asp-action="Index" asp-route-categoryId="3">Books</a>
                <a asp-controller="Products" asp-action="Index" asp-route-categoryId="4">Home & Garden</a>
            </div>
            <div class="footer-col">
                <h4>HELP</h4>
                <a href="#">Shipping Info</a>
                <a href="#">Returns</a>
                <a href="#">Size Guide</a>
                <a href="#">Contact Us</a>
                <a href="#">FAQ</a>
            </div>
            <div class="footer-col">
                <h4>ABOUT</h4>
                <a href="#">Our Story</a>
                <a href="#">Careers</a>
                <a href="#">Press</a>
                <a href="#">Sustainability</a>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year SHOPNET. ALL RIGHTS RESERVED.</span>
            <div class="footer-legal">
                <a href="#">PRIVACY POLICY</a>
                <a href="#">TERMS OF SERVICE</a>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Sticky header on scroll
        window.addEventListener('scroll', () => {
        const header = document.getElementById('site-header');
        header.classList.toggle('scrolled', window.scrollY > 50);
        });

        // Mobile menu toggle
        document.getElementById('mobileMenuBtn')?.addEventListener('click', () => {
        document.getElementById('mobileMenu').classList.toggle('open');
        });

        // Live cart count badge
        (async () => {
        try {
        const res  = await fetch('/Cart/Count');
        const data = await res.json();
        const badge = document.getElementById('cart-count');
        if (badge) {
        badge.textContent = data.count;
        badge.style.display = data.count > 0 ? 'flex' : 'none';
        }
        } catch { /* fail silently — badge stays at 0 */ }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
